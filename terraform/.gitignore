# Terraform state — nunca commitear
*.tfstate
*.tfstate.backup
*.tfstate.lock.info

# Directorio de trabajo del provider
.terraform/
.terraform.lock.hcl

# Valores reales de variables (pueden contener secrets)
terraform.tfvars

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI config
.terraformrc
terraform.rc
